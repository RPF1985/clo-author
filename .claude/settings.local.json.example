{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Copy this file to settings.local.json and customize for your machine. settings.local.json is gitignored.",
  "permissions": {
    "allow": [
      "WebSearch(*)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:scholar.google.com)",
      "WebFetch(domain:api.semanticscholar.org)",
      "WebFetch(domain:api.openalex.org)"
    ],
    "deny": [
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.gnupg/*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials.json)",
      "Read(**/secrets.*)",
      "Write(~/.ssh/*)",
      "Write(~/.aws/*)",
      "Write(~/.gnupg/*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(~/.ssh/*)",
      "Edit(~/.aws/*)",
      "Edit(~/.gnupg/*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)"
    ]
  }
}
